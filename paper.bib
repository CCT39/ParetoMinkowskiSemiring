@inproceedings{Hansen1980,
  author    = {Pierre Hansen},
  editor    = {G{\"u}nter Fandel and Tomas Gal},
  title     = {Bicriterion Path Problems},
  booktitle = {Multiple Criteria Decision Making Theory and Application},
